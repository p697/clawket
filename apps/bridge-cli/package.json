{
  "name": "@p697/clawket",
  "version": "0.5.1",
  "private": false,
  "type": "module",
  "license": "AGPL-3.0-only",
  "description": "Clawket CLI for pairing and running the Relay bridge runtime",
  "bin": {
    "clawket": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:bundle": "pnpm --filter @clawket/bridge-core run build && pnpm --filter @clawket/bridge-runtime run build && node scripts/build-bundle.mjs",
    "build": "pnpm run build:bundle",
    "typecheck": "pnpm --filter @clawket/bridge-core run build && pnpm --filter @clawket/bridge-runtime run build && tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @clawket/bridge-core run build && pnpm --filter @clawket/bridge-runtime run build && vitest run --passWithNoTests",
    "status": "node scripts/run-command.mjs status",
    "doctor": "node scripts/run-command.mjs doctor",
    "logs": "node scripts/run-command.mjs logs",
    "cmd:install": "node scripts/run-command.mjs install",
    "start": "node scripts/run-command.mjs start",
    "restart": "node scripts/run-command.mjs restart",
    "stop": "node scripts/run-command.mjs stop",
    "uninstall": "node scripts/run-command.mjs uninstall",
    "reset": "node scripts/run-command.mjs reset",
    "refresh-code": "node scripts/run-command.mjs refresh-code",
    "verify:package": "node scripts/verify-package.mjs",
    "prepack": "pnpm run build && pnpm run verify:package",
    "publish:dry-run": "pnpm publish --dry-run",
    "pair": "node scripts/run-command.mjs pair",
    "run": "node scripts/run-command.mjs run"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@clawket/bridge-core": "workspace:*",
    "@clawket/bridge-runtime": "workspace:*",
    "@types/qrcode": "^1.5.6",
    "tsup": "^8.5.0"
  }
}
