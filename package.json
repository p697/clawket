{
  "name": "clawket",
  "private": true,
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^22.13.9",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.4.0"
  },
  "overrides": {
    "expo": "~55.0.9",
    "expo-modules-core": "~55.0.18",
    "jest-expo": "~55.0.11"
  },
  "scripts": {
    "postinstall": "node scripts/setup-mobile-node-modules.mjs",
    "typecheck": "pnpm mobile:typecheck && pnpm relay:typecheck && pnpm bridge:typecheck",
    "test": "pnpm mobile:test -- --runInBand && pnpm relay:test && pnpm bridge:test",
    "build": "pnpm mobile:office:build && pnpm bridge:build",
    "mobile:prepare": "pnpm mobile:office:build",
    "mobile:start": "pnpm mobile:prepare && pnpm --workspace clawket start",
    "mobile:ios": "pnpm mobile:prepare && pnpm --workspace clawket ios",
    "mobile:android": "pnpm mobile:prepare && pnpm --workspace clawket android",
    "mobile:sync:native": "pnpm --workspace clawket prebuild:clean && pnpm --workspace clawket pod-install:ios",
    "mobile:dev:ios": "pnpm mobile:prepare && pnpm --workspace clawket dev",
    "mobile:dev:android": "pnpm mobile:prepare && pnpm --workspace clawket dev:android",
    "mobile:dev:macos": "pnpm mobile:prepare && pnpm --workspace clawket dev:macos",
    "mobile:build:macos": "pnpm mobile:prepare && pnpm --workspace clawket build:macos",
    "mobile:archive:macos": "pnpm mobile:prepare && pnpm --workspace clawket archive:macos",
    "mobile:export:macos": "pnpm mobile:prepare && pnpm --workspace clawket export:macos",
    "mobile:build:android:pro-temp": "pnpm mobile:prepare && pnpm --workspace clawket build:android:pro-temp",
    "mobile:config:show": "pnpm --workspace clawket config:show",
    "mobile:config:check": "pnpm --workspace clawket config:check",
    "mobile:config:check:ios": "pnpm --workspace clawket config:check:ios",
    "mobile:typecheck": "pnpm --workspace clawket typecheck",
    "mobile:test": "pnpm --workspace clawket test",
    "mobile:office:build": "pnpm --prefix apps/mobile/office-game install && pnpm --prefix apps/mobile/office-game run build",
    "relay:typecheck": "pnpm --workspace @clawket/shared typecheck && pnpm --workspace @clawket/registry-worker typecheck && pnpm --workspace @clawket/relay-worker typecheck",
    "relay:test": "pnpm --workspace @clawket/shared test && pnpm --workspace @clawket/registry-worker test && pnpm --workspace @clawket/relay-worker test",
    "relay:test:integration": "vitest run --dir tests/integration",
    "relay:dev:registry": "node scripts/relay/run-wrangler.mjs dev relay-registry",
    "relay:dev:worker": "node scripts/relay/run-wrangler.mjs dev relay-worker",
    "relay:deploy:registry": "node scripts/relay/run-wrangler.mjs deploy relay-registry",
    "relay:deploy:worker": "node scripts/relay/run-wrangler.mjs deploy relay-worker",
    "relay:tail:registry": "node scripts/relay/run-wrangler.mjs tail relay-registry",
    "relay:tail:worker": "node scripts/relay/run-wrangler.mjs tail relay-worker",
    "relay:cf:login": "wrangler login",
    "relay:cf:whoami": "wrangler whoami",
    "relay:cf:logout": "wrangler logout",
    "bridge:build": "pnpm --workspace @clawket/bridge-core build && pnpm --workspace @clawket/bridge-runtime build && pnpm --workspace @p697/clawket build",
    "bridge:test": "pnpm --workspace @clawket/bridge-core test && pnpm --workspace @clawket/bridge-runtime test && pnpm --workspace @p697/clawket test",
    "bridge:typecheck": "pnpm --workspace @clawket/bridge-core build && pnpm --workspace @clawket/bridge-runtime build && pnpm --workspace @p697/clawket typecheck",
    "bridge:cli:build": "pnpm --workspace @p697/clawket build",
    "bridge:cli:verify-package": "pnpm --workspace @p697/clawket verify:package",
    "bridge:cli:publish:dry-run": "pnpm --workspace @p697/clawket publish:dry-run",
    "bridge:publish": "node scripts/bridge/publish-cli.mjs",
    "bridge:pair": "pnpm --workspace @p697/clawket pair --",
    "bridge:pair:local": "pnpm --workspace @p697/clawket pair -- --local",
    "bridge:refresh-code": "pnpm --workspace @p697/clawket refresh-code --",
    "bridge:install": "pnpm --workspace @p697/clawket cmd:install --",
    "bridge:start": "pnpm --workspace @p697/clawket start --",
    "bridge:restart": "pnpm --workspace @p697/clawket restart --",
    "bridge:stop": "pnpm --workspace @p697/clawket stop --",
    "bridge:uninstall": "pnpm --workspace @p697/clawket uninstall --",
    "bridge:reset": "pnpm --workspace @p697/clawket reset --",
    "bridge:status": "pnpm --workspace @p697/clawket status --",
    "bridge:logs": "pnpm --workspace @p697/clawket logs --",
    "bridge:doctor": "pnpm --workspace @p697/clawket doctor --",
    "bridge:run": "pnpm --workspace @p697/clawket run --"
  }
}
